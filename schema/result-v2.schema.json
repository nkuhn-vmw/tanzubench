{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tanzubench.example.com/schema/result-v2.json",
  "title": "TanzuBench Result v2",
  "type": "object",
  "required": [
    "schema_version",
    "result_type",
    "meta",
    "target",
    "engine",
    "hardware",
    "grading",
    "tests",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "2.0.0"
    },
    "result_type": {
      "enum": [
        "suite",
        "speed",
        "accuracy",
        "scale",
        "comparison"
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp",
        "foundation"
      ],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "foundation": {
          "type": "string",
          "minLength": 1
        },
        "tile_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "tag": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_file": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "family": {
          "type": [
            "string",
            "null"
          ]
        },
        "parameters_b": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "active_parameters_b": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "architecture": {
          "type": [
            "string",
            "null"
          ]
        },
        "quant": {
          "type": [
            "string",
            "null"
          ]
        },
        "size_gb": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "config"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "ollama",
            "vllm",
            "other"
          ]
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        },
        "config": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "hardware": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gpu_count"
      ],
      "properties": {
        "vm_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "cpu": {
          "type": [
            "string",
            "null"
          ]
        },
        "cpu_cores": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "ram_gb": {
          "type": [
            "number",
            "string",
            "null"
          ]
        },
        "gpu_count": {
          "type": "integer",
          "minimum": 0
        },
        "gpu_model": {
          "type": [
            "string",
            "null"
          ]
        },
        "gpu_memory_gb": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "power_limit_watts": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "gpu_count": {
                "minimum": 1
              }
            },
            "required": [
              "gpu_count"
            ]
          },
          "then": {
            "required": [
              "gpu_model"
            ]
          }
        }
      ]
    },
    "grading": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "judge_configured",
        "skipped_categories"
      ],
      "properties": {
        "judge_configured": {
          "type": "boolean"
        },
        "judge_model": {
          "type": [
            "string",
            "null"
          ]
        },
        "judge_endpoint": {
          "type": [
            "string",
            "null"
          ]
        },
        "judge_fingerprint": {
          "type": [
            "string",
            "null"
          ]
        },
        "judge_run_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "skipped_categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "category",
          "grader",
          "score",
          "max_score",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "grader": {
            "type": "string",
            "enum": [
              "exact_match",
              "contains",
              "regex",
              "tool_call",
              "needle",
              "file_check",
              "exec_unit_tests",
              "llm_judge",
              "json_schema",
              "multi_turn",
              "agentic",
              "exec_build",
              "container_exec"
            ]
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "max_score": {
            "type": "number",
            "minimum": 0
          },
          "status": {
            "type": "string",
            "enum": [
              "scored",
              "skipped",
              "timeout",
              "error"
            ]
          },
          "agent_framework": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "opencode",
              "aider",
              "custom",
              null
            ]
          },
          "prompt_tokens": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "completion_tokens": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "elapsed_ms": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "tok_per_sec": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          },
          "judge": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": true
          },
          "raw_response": {
            "type": [
              "string",
              "null"
            ]
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "headline_metric",
        "headline_value",
        "composite_score",
        "composite_over",
        "category_scores"
      ],
      "properties": {
        "headline_metric": {
          "type": "string",
          "minLength": 1
        },
        "headline_value": {
          "type": "number",
          "minimum": 0
        },
        "headline_unit": {
          "type": [
            "string",
            "null"
          ]
        },
        "composite_score": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "composite_max": {
          "type": "number",
          "minimum": 0
        },
        "composite_over": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "total_time_ms": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "category_scores": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "category",
              "score",
              "max",
              "tasks",
              "status"
            ],
            "properties": {
              "category": {
                "type": "string",
                "minLength": 1
              },
              "score": {
                "type": [
                  "number",
                  "null"
                ],
                "minimum": 0,
                "maximum": 1
              },
              "max": {
                "type": "number",
                "minimum": 0
              },
              "tasks": {
                "type": "integer",
                "minimum": 0
              },
              "status": {
                "type": "string",
                "enum": [
                  "scored",
                  "skipped"
                ]
              },
              "avg_tok_per_sec": {
                "type": [
                  "number",
                  "null"
                ],
                "minimum": 0
              },
              "avg_elapsed_ms": {
                "type": [
                  "number",
                  "null"
                ],
                "minimum": 0
              }
            }
          }
        },
        "agent_framework_scores": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "framework",
              "score",
              "tasks"
            ],
            "properties": {
              "framework": {
                "type": "string",
                "enum": [
                  "opencode",
                  "aider",
                  "custom"
                ]
              },
              "score": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "tasks": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    }
  }
}
# GenAI Perf Bench — environment variables
# Copy to .env and fill in your values. Never commit .env to git.

# Target model endpoint (the model being benchmarked)
BENCH_URL=http://127.0.0.1:4000
BENCH_API_KEY=
BENCH_MODEL=google/gemma-4-31B-it
BENCH_ENGINE=vllm               # vllm | ollama | other

# Judge endpoint (for reasoning/writing/research categories)
JUDGE_URL=
JUDGE_MODEL=
JUDGE_API_KEY=

# Foundation + hardware (used for result file organization)
BENCH_FOUNDATION=tdc
BENCH_HARDWARE=gpu               # cpu | gpu
BENCH_GPU_COUNT=0
BENCH_GPU_MODEL=

# Optional overrides
# BENCH_TASK_TIMEOUT=120         # per-test cap for CPU runs
# BENCH_MAX_RUN_TIME=7200        # total wall-clock cap
# BENCH_SUPPRESS_THINKING=true   # for Gemma 4 / Qwen3 family
